// Phase 1 — Pipeline schema.
// Layer 2 RAG now stores vectors in the SQL-managed `vector_store` table via
// Supabase RPC functions. That table intentionally lives outside Prisma because
// Prisma still cannot model pgvector cleanly enough for the similarity-search
// operators this project uses.

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Ticket {
  id             String       @id @default(cuid())
  jiraTicketId   String       @unique
  jiraKey        String
  rawPayload     Json
  normalizedData Json
  status         TicketStatus
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  pipeline       Pipeline?
}

/// Canonical synced copy of Jira issues (all statuses in configured projects).
model JiraIssue {
  id            String    @id @default(cuid())
  jiraTicketId  String    @unique
  jiraKey       String    @unique
  projectKey    String
  summary       String
  description   String    @db.Text
  issueType     String
  status        String
  priority      String?
  reporter      String?
  assignee      String?
  labels        Json      @default("[]")
  components    Json      @default("[]")
  commentsText  String?   @db.Text
  resolution    String?
  gitContext    String?   @db.Text
  rawPayload    Json?
  jiraUpdatedAt DateTime?
  embeddedAt    DateTime?
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectKey, status])
  @@index([jiraUpdatedAt])
  @@index([isDeleted])
}

model JiraSyncRun {
  id            String          @id @default(cuid())
  mode          JiraSyncMode
  status        JiraSyncStatus
  startedAt     DateTime        @default(now())
  completedAt   DateTime?
  issuesSynced  Int             @default(0)
  issuesSkipped Int             @default(0)
  errors        Int             @default(0)
  errorMessage  String?         @db.Text
  watermark     DateTime?

  @@index([status, startedAt])
}

/// Selective mirror of closed/done Jira issues for pipeline RAG (Lane 2).
/// @deprecated Prefer JiraIssue — kept for backward compatibility during migration.
model JiraMirror {
  id            String    @id @default(cuid())
  jiraTicketId  String    @unique
  jiraKey       String    @unique
  projectKey    String
  summary       String
  description   String    @db.Text
  issueType     String
  status        String
  priority      String?
  labels        Json      @default("[]")
  components    Json      @default("[]")
  commentsText  String?   @db.Text
  resolution    String?
  gitContext    String?   @db.Text
  embeddedAt    DateTime?
  jiraUpdatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([projectKey])
  @@index([jiraUpdatedAt])
}

model Pipeline {
  id           String             @id @default(cuid())
  ticketId     String             @unique
  ticket       Ticket             @relation(fields: [ticketId], references: [id])
  currentStage PipelineStage
  status       PipelineStatus
  startedAt    DateTime           @default(now())
  completedAt  DateTime?
  stages       PipelineStageLog[]
  overrides    HumanOverride[]
  auditLogs    AuditLog[]
  canaryRuns   CanaryRun[]
}

model CanaryRun {
  id           String          @id @default(cuid())
  pipelineId   String?
  pipeline     Pipeline?       @relation(fields: [pipelineId], references: [id])
  jiraKey      String?
  trigger      String          @default("manual")
  environment  String          @default("staging")
  scope        String          @default("full")
  targetUrl    String
  status       CanaryRunStatus @default(PENDING)
  phase        String?
  understanding Json?
  hypotheses   Json?
  summary      String?         @db.Text
  metadata     Json            @default("{}")
  error        String?         @db.Text
  startedAt    DateTime        @default(now())
  completedAt  DateTime?
  findings     CanaryFinding[]

  @@index([pipelineId])
  @@index([status, environment])
  @@index([jiraKey])
}

model CanaryFinding {
  id              String    @id @default(cuid())
  canaryRunId     String
  canaryRun       CanaryRun @relation(fields: [canaryRunId], references: [id], onDelete: Cascade)
  hypothesisId    String?
  severity        String
  category        String
  title           String
  description     String    @db.Text
  reproductionSteps String? @db.Text
  evidence        Json?
  affectedCode    String?
  suggestedFix    String?   @db.Text
  jiraKeyCreated  String?
  embeddedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([canaryRunId, severity])
}

model PipelineStageLog {
  id               String        @id @default(cuid())
  pipelineId       String
  pipeline         Pipeline      @relation(fields: [pipelineId], references: [id])
  stage            PipelineStage
  status           StageStatus
  input            Json
  output           Json?
  validationResult Json?
  confidenceScore  Float?
  tokenCount       Int?
  costUsd          Float?
  startedAt        DateTime      @default(now())
  completedAt      DateTime?
  error            String?

  @@index([pipelineId, stage])
}

model HumanOverride {
  id              String        @id @default(cuid())
  pipelineId      String
  pipeline        Pipeline      @relation(fields: [pipelineId], references: [id])
  stage           PipelineStage
  originalOutput  Json
  correctedOutput Json
  reason          String?
  overriddenBy    String
  overriddenAt    DateTime      @default(now())

  @@index([pipelineId, stage])
}

model OrgIntelligenceRecord {
  id         String   @id @default(cuid())
  sourceType String
  jiraKey    String
  pipelineId String?
  component  String?
  signal     String   @db.Text
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([jiraKey, createdAt])
  @@index([sourceType, createdAt])
  @@index([component])
}

model CompanyProfile {
  id              String        @id @default(cuid())
  organizationId  String?       @unique
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyName     String        @default("")
  website         String        @default("")
  productSummary  String        @default("") @db.Text
  icp             String        @default("") @db.Text
  revenueModel    String        @default("") @db.Text
  pricingSummary  String        @default("") @db.Text
  businessContext String        @default("") @db.Text
  strategicGoals  Json          @default("[]")
  nonGoals        Json          @default("[]")
  competitors     Json          @default("[]")
  updatedAt       DateTime      @updatedAt
  updatedBy       String?
}

model User {
  id          String               @id @default(cuid())
  email       String               @unique
  name        String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  memberships OrganizationMember[]
}

model Organization {
  id             String                  @id @default(cuid())
  name           String
  slug           String                  @unique
  domain         String                  @unique
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  members        OrganizationMember[]
  companyProfile CompanyProfile?
  jiraConfig     OrganizationJiraConfig?
  billing        WorkspaceBilling?
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole      @default(MEMBER)
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model OrganizationJiraConfig {
  organizationId        String       @id
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  baseUrl               String       @default("")
  email                 String       @default("")
  apiToken              String       @default("")
  webhookSecret         String       @default("")
  projectKeysJson       Json         @default("[]")
  boardId               String?
  aiWorkerColumnName    String?
  aiWorkerStatusesJson  Json?
  completionSettingsJson Json?
  updatedAt             DateTime     @updatedAt
}

model AgentChatThread {
  id          String   @id @default(cuid())
  agentDomain String
  contextKey  String   @default("")
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  messages    AgentChatMessage[]

  @@unique([agentDomain, contextKey])
  @@index([agentDomain])
}

model AgentChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  thread    AgentChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  event      String
  metadata   Json
  timestamp  DateTime @default(now())

  @@index([pipelineId, timestamp])
}

model CodebaseVisualizationCache {
  id          String   @id @default(cuid())
  repoOwner   String
  repoName    String
  branchName  String
  layoutJson  Json
  computedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([repoOwner, repoName, branchName])
  @@index([computedAt])
}

model CodebaseTourCache {
  id          String   @id @default(cuid())
  repoOwner   String
  repoName    String
  branchName  String
  tourJson    Json
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([repoOwner, repoName, branchName])
}

model CodebaseKnowledgeCache {
  id            String   @id @default(cuid())
  repoOwner     String
  repoName      String
  branchName    String
  knowledgeJson Json
  generatedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([repoOwner, repoName, branchName])
}

model CodebaseFile {
  id            String   @id @default(cuid())
  repoOwner     String
  repoName      String
  filePath      String
  branchName    String
  content       String   @db.Text
  contentHash   String
  size          Int
  language      String?
  summary       String?  @db.Text
  exports       Json
  imports       Json
  patterns      Json
  lastCommitSha String?
  lastCommitMsg String?
  lastCommitAt  DateTime?
  lastAuthor    String?
  indexedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDeleted     Boolean  @default(false)

  @@unique([repoOwner, repoName, filePath, branchName])
  @@index([repoOwner, repoName, branchName])
  @@index([language])
  @@index([contentHash])
}

model BranchState {
  id           String   @id @default(cuid())
  repoOwner    String
  repoName     String
  branchName   String
  sourceBranch String
  jiraKey      String?
  createdBy    String
  headSha      String
  behindBy     Int      @default(0)
  aheadBy      Int      @default(0)
  prNumber     Int?
  prUrl        String?
  prStatus     String?
  filesChanged Json
  lastPushAt   DateTime?
  lastPushBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([repoOwner, repoName, branchName])
  @@index([jiraKey])
}

model CommitHistory {
  id            String   @id @default(cuid())
  repoOwner     String
  repoName      String
  branchName    String
  sha           String
  message       String
  author        String
  authoredAt    DateTime
  filesAdded    Json
  filesModified Json
  filesDeleted  Json
  pushedBy      String
  pipelineId    String?
  jiraKey       String?
  createdAt     DateTime @default(now())

  @@unique([repoOwner, repoName, sha])
  @@index([branchName])
  @@index([jiraKey])
}

model CodebaseIndexRun {
  id              String   @id @default(cuid())
  repoOwner       String
  repoName        String
  branchName      String
  runType         String
  status          String
  filesTotal      Int      @default(0)
  filesProcessed  Int      @default(0)
  filesIndexed    Int      @default(0)
  filesUpdated    Int      @default(0)
  filesDeleted    Int      @default(0)
  triggerType     String
  triggerSha      String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  error           String?

  @@index([repoOwner, repoName, status])
  @@index([startedAt])
}

model WorkspaceBilling {
  id             String        @id @default(cuid())
  organizationId String?       @unique
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId         String        @default("pilot")
  runsUsed       Int           @default(0)
  runsCap        Int           @default(20)
  pilotEndsAt    DateTime?
  billingCycle   String        @default("monthly")
  updatedAt      DateTime      @updatedAt
}

model GithubInstallation {
  id                String             @id @default(cuid())
  installationId    String             @unique
  accountLogin      String
  accountType       String
  targetType        String?
  permissionsJson   Json?
  eventsJson        Json?
  suspendedAt       DateTime?
  selectedRepoOwner String?
  selectedRepoName  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  repositories      GithubRepository[]

  @@index([accountLogin])
}

model GithubRepository {
  id             String             @id @default(cuid())
  installationId String
  githubRepoId   Int
  owner          String
  name           String
  fullName       String
  defaultBranch  String             @default("main")
  private        Boolean            @default(false)
  selected       Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  installation   GithubInstallation @relation(fields: [installationId], references: [installationId], onDelete: Cascade)

  @@unique([installationId, githubRepoId])
  @@index([fullName])
  @@index([installationId, selected])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum TicketStatus {
  RECEIVED
  PROCESSING
  AWAITING_HUMAN
  COMPLETED
  FAILED
}

enum PipelineStage {
  INGESTION
  PRODUCT_AGENT
  PRD_VALIDATION
  ENGINEERING_AGENT
  IMPLEMENTATION_VALIDATION
  QA_AGENT
  QA_VALIDATION
  OUTPUT
}

enum PipelineStatus {
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum StageStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  AWAITING_HUMAN
}

enum JiraSyncMode {
  FULL
  INCREMENTAL
}

enum JiraSyncStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum CanaryRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
