// Phase 1 — Pipeline schema.
// Layer 2 RAG now stores vectors in the SQL-managed `vector_store` table via
// Supabase RPC functions. That table intentionally lives outside Prisma because
// Prisma still cannot model pgvector cleanly enough for the similarity-search
// operators this project uses.

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Ticket {
  id             String       @id @default(cuid())
  jiraTicketId   String       @unique
  jiraKey        String
  rawPayload     Json
  normalizedData Json
  status         TicketStatus
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  pipeline       Pipeline?
}

model Pipeline {
  id           String             @id @default(cuid())
  ticketId     String             @unique
  ticket       Ticket             @relation(fields: [ticketId], references: [id])
  currentStage PipelineStage
  status       PipelineStatus
  startedAt    DateTime           @default(now())
  completedAt  DateTime?
  stages       PipelineStageLog[]
  overrides    HumanOverride[]
  auditLogs    AuditLog[]
}

model PipelineStageLog {
  id               String        @id @default(cuid())
  pipelineId       String
  pipeline         Pipeline      @relation(fields: [pipelineId], references: [id])
  stage            PipelineStage
  status           StageStatus
  input            Json
  output           Json?
  validationResult Json?
  confidenceScore  Float?
  tokenCount       Int?
  costUsd          Float?
  startedAt        DateTime      @default(now())
  completedAt      DateTime?
  error            String?

  @@index([pipelineId, stage])
}

model HumanOverride {
  id              String        @id @default(cuid())
  pipelineId      String
  pipeline        Pipeline      @relation(fields: [pipelineId], references: [id])
  stage           PipelineStage
  originalOutput  Json
  correctedOutput Json
  reason          String?
  overriddenBy    String
  overriddenAt    DateTime      @default(now())

  @@index([pipelineId, stage])
}

model AuditLog {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  event      String
  metadata   Json
  timestamp  DateTime @default(now())

  @@index([pipelineId, timestamp])
}

model CodebaseVisualizationCache {
  id          String   @id @default(cuid())
  repoOwner   String
  repoName    String
  branchName  String
  layoutJson  Json
  computedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([repoOwner, repoName, branchName])
  @@index([computedAt])
}

model CodebaseTourCache {
  id          String   @id @default(cuid())
  repoOwner   String
  repoName    String
  branchName  String
  tourJson    Json
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([repoOwner, repoName, branchName])
}

model CodebaseKnowledgeCache {
  id            String   @id @default(cuid())
  repoOwner     String
  repoName      String
  branchName    String
  knowledgeJson Json
  generatedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([repoOwner, repoName, branchName])
}

model CodebaseFile {
  id            String   @id @default(cuid())
  repoOwner     String
  repoName      String
  filePath      String
  branchName    String
  content       String   @db.Text
  contentHash   String
  size          Int
  language      String?
  summary       String?  @db.Text
  exports       Json
  imports       Json
  patterns      Json
  lastCommitSha String?
  lastCommitMsg String?
  lastCommitAt  DateTime?
  lastAuthor    String?
  indexedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDeleted     Boolean  @default(false)

  @@unique([repoOwner, repoName, filePath, branchName])
  @@index([repoOwner, repoName, branchName])
  @@index([language])
  @@index([contentHash])
}

model BranchState {
  id           String   @id @default(cuid())
  repoOwner    String
  repoName     String
  branchName   String
  sourceBranch String
  jiraKey      String?
  createdBy    String
  headSha      String
  behindBy     Int      @default(0)
  aheadBy      Int      @default(0)
  prNumber     Int?
  prUrl        String?
  prStatus     String?
  filesChanged Json
  lastPushAt   DateTime?
  lastPushBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([repoOwner, repoName, branchName])
  @@index([jiraKey])
}

model CommitHistory {
  id            String   @id @default(cuid())
  repoOwner     String
  repoName      String
  branchName    String
  sha           String
  message       String
  author        String
  authoredAt    DateTime
  filesAdded    Json
  filesModified Json
  filesDeleted  Json
  pushedBy      String
  pipelineId    String?
  jiraKey       String?
  createdAt     DateTime @default(now())

  @@unique([repoOwner, repoName, sha])
  @@index([branchName])
  @@index([jiraKey])
}

model CodebaseIndexRun {
  id              String   @id @default(cuid())
  repoOwner       String
  repoName        String
  branchName      String
  runType         String
  status          String
  filesTotal      Int      @default(0)
  filesProcessed  Int      @default(0)
  filesIndexed    Int      @default(0)
  filesUpdated    Int      @default(0)
  filesDeleted    Int      @default(0)
  triggerType     String
  triggerSha      String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  error           String?

  @@index([repoOwner, repoName, status])
  @@index([startedAt])
}

model GithubInstallation {
  id                String             @id @default(cuid())
  installationId    String             @unique
  accountLogin      String
  accountType       String
  targetType        String?
  permissionsJson   Json?
  eventsJson        Json?
  suspendedAt       DateTime?
  selectedRepoOwner String?
  selectedRepoName  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  repositories      GithubRepository[]

  @@index([accountLogin])
}

model GithubRepository {
  id             String             @id @default(cuid())
  installationId String
  githubRepoId   Int
  owner          String
  name           String
  fullName       String
  defaultBranch  String             @default("main")
  private        Boolean            @default(false)
  selected       Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  installation   GithubInstallation @relation(fields: [installationId], references: [installationId], onDelete: Cascade)

  @@unique([installationId, githubRepoId])
  @@index([fullName])
  @@index([installationId, selected])
}

enum TicketStatus {
  RECEIVED
  PROCESSING
  AWAITING_HUMAN
  COMPLETED
  FAILED
}

enum PipelineStage {
  INGESTION
  PRODUCT_AGENT
  PRD_VALIDATION
  ENGINEERING_AGENT
  IMPLEMENTATION_VALIDATION
  QA_AGENT
  QA_VALIDATION
  OUTPUT
}

enum PipelineStatus {
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum StageStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  AWAITING_HUMAN
}
