{
  "name": "agentos-server",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev:tsx": "tsx watch src/server.ts",
    "build": "npx prisma generate && tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/jira-intake/db','dist/jira-intake/db',{recursive:true})\"",
    "postinstall": "prisma generate",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "test:discovery": "tsx scripts/testDiscovery.ts",
    "test:scoring": "tsx --test src/discovery/scoring.test.ts",
    "test:roi": "tsx --test src/roi/estimatedRoi.test.ts",
    "test:chunker": "tsx --test src/codebaseIntelligence/astChunker.test.ts",
    "test:chunking": "tsx --test src/rag/chunking.test.ts",
    "test:workspace": "tsx --test src/engineering/engineeringWorkspace.test.ts",
    "test:compile": "tsx --test src/engineering/workspaceCompile.test.ts",
    "probe:ananta": "tsx scripts/ananta-layer-probe.ts",
    "test:ananta-layers": "tsx scripts/ananta-layer-test.ts",
    "eval:retrieval": "tsx scripts/eval-retrieval.ts"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.2",
    "@anthropic-ai/sdk": "^0.50.3",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@sentry/node": "^8.40.0",
    "@supabase/supabase-js": "^2.105.4",
    "better-sqlite3": "^11.10.0",
    "d3": "^7.9.0",
    "d3-voronoi-map": "^2.1.1",
    "d3-voronoi-treemap": "^1.1.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "js-tiktoken": "^1.0.21",
    "openai": "^4.71.0",
    "pg": "^8.16.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^7.0.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-go": "^0.21.2",
    "tree-sitter-java": "^0.21.0",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-ruby": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-sql": "^0.1.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.21.2",
    "tree-sitter-yaml": "^0.5.0",
    "undici": "^7.16.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.15.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
