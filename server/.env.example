NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Postgres (Supabase). Must have pgvector extension enabled.
DATABASE_URL=postgresql://user:password@host:5432/agentos?schema=public
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Model providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=

# Monitoring
SENTRY_DSN=
