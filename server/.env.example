NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Comma-separated origins allowed to call the API (production UI on Vercel)
# CORS_ORIGIN=https://agentos-orcin.vercel.app,http://localhost:5173

# Postgres (Supabase). Must have pgvector extension enabled.
# Dashboard → Connect → Session pooler (port 5432). Example:
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
# sslmode in the URL is optional — the server sets ssl for Supabase pooler automatically.
DATABASE_URL=postgresql://postgres:ZoroXRoronoa@db.zuyjnioxengnouczypcl.supabase.co:5432/postgres

SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings → API → service_role (secret). Never commit the real value.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# OpenAI — required for agents, codebase intelligence, embeddings, and search
OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-5.1   # default; also used for summaries, ask, tour, and pipeline agents
# OPENAI_MODEL=gpt-5.1        # alias for OPENAI_CHAT_MODEL
# OPENAI_SUMMARY_MODEL=gpt-5.1

# GitHub App (one-click — preferred)
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=agentos-your-slug
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_APP_PRIVATE_KEY=   # Full PEM from GitHub, or base64 body only (server adds BEGIN/END headers)
# GITHUB_APP_WEBHOOK_SECRET=
# GITHUB_OAUTH_STATE_SECRET=   # optional; defaults to webhook secret for install CSRF state
# GITHUB_APP_INSTALLATION_ID=   # optional env fallback
# FRONTEND_URL=https://your-app.vercel.app

# Git provider manual fallback (Codebase Intelligence):
# GitHub
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_WEBHOOK_SECRET=
# Bitbucket (alternative)
# BITBUCKET_USERNAME=
# BITBUCKET_APP_PASSWORD=
# BITBUCKET_WORKSPACE=
# BITBUCKET_REPO_SLUG=
# BITBUCKET_WEBHOOK_SECRET=
# GIT_DEFAULT_BRANCH=main
# Codebase visualization layout cache is stored in Postgres (CodebaseVisualizationCache)
# QA sandbox test runs (clone branch, run Vitest/Jest)
# SANDBOX_DIR=/tmp/agentos-qa-sandbox
# QA_DEFAULT_BRANCH=main
# TEST_DATABASE_URL=

# Pipeline Jira — connect, AI Worker intake column, agent pipeline + mirror
# Falls back to JIRA_* when PIPELINE_JIRA_* is unset.
PIPELINE_JIRA_BASE_URL=
PIPELINE_JIRA_EMAIL=
PIPELINE_JIRA_API_TOKEN=
PIPELINE_JIRA_WEBHOOK_SECRET=
PIPELINE_JIRA_PROJECT_KEYS=PROJ
PIPELINE_JIRA_BOARD_ID=
# Statuses that trigger the pipeline when a ticket enters them (usually one column)
PIPELINE_JIRA_AI_WORKER_STATUSES=AI Worker
# Selective mirror: closed/done tickets embedded for RAG
PIPELINE_JIRA_MIRROR_STATUSES=Done,Closed,Resolved
PIPELINE_JIRA_MIRROR_TYPES=Story,Bug,Task
PIPELINE_JIRA_MIRROR_MONTHS=12
PIPELINE_JIRA_MIRROR_MIN_DESC=20
PIPELINE_JIRA_MIRROR_MAX_COMMENTS=15
JIRA_STORY_POINTS_FIELD=

# SQLite stores git + pipeline Jira credentials locally
# SQLITE_PATH=./data/jira-intake.db

# Auth: demo@agentos.ai / agentos123 works by default. Set true to allow any email+8+ char password.
# AUTH_ALLOW_ANY_LOGIN=true

# Optional: pipeline worker parallelism (default 2)
# PIPELINE_WORKER_CONCURRENCY=2

# Monitoring
SENTRY_DSN=
