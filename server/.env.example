NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Comma-separated origins allowed to call the API (production UI on Vercel)
# CORS_ORIGIN=https://agentos-orcin.vercel.app,http://localhost:5173

# Postgres (Supabase). Must have pgvector extension enabled.
# Dashboard → Connect → Session pooler (port 5432). Example:
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
# sslmode in the URL is optional — the server sets ssl for Supabase pooler automatically.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres

SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings → API → service_role (secret). Never commit the real value.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Claude agents: bedrock (default in this project) or anthropic
LLM_PROVIDER=bedrock
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-40-character-secret-access-key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
# AWS_SESSION_TOKEN=   # only if using temporary credentials

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_ID=claude-sonnet-4-20250514

OPENAI_API_KEY=

# GitHub App (one-click — preferred)
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=agentos-your-slug
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_WEBHOOK_SECRET=
# GITHUB_OAUTH_STATE_SECRET=   # optional; defaults to webhook secret for install CSRF state
# GITHUB_APP_INSTALLATION_ID=   # optional env fallback
# FRONTEND_URL=https://your-app.vercel.app

# Git provider manual fallback (Codebase Intelligence):
# GitHub
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_WEBHOOK_SECRET=
# Bitbucket (alternative)
# BITBUCKET_USERNAME=
# BITBUCKET_APP_PASSWORD=
# BITBUCKET_WORKSPACE=
# BITBUCKET_REPO_SLUG=
# BITBUCKET_WEBHOOK_SECRET=
# GIT_DEFAULT_BRANCH=main
# Codebase visualization layout cache uses Redis (same REDIS_URL) + Postgres CodebaseVisualizationCache
# QA sandbox test runs (clone branch, run Vitest/Jest)
# SANDBOX_DIR=/tmp/agentos-qa-sandbox
# QA_DEFAULT_BRANCH=main
# TEST_DATABASE_URL=

# Jira (pipelines + board search + AI Worker intake)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_BOARD_ID=
# Public URL shown in the Jira integration UI (your Render host)
# PUBLIC_API_URL=https://agentos-api.onrender.com
JIRA_WEBHOOK_SECRET=

# AI Worker intake (SQLite queue — no Postgres required)
AI_WORKER_STATUSES=AI Worker
# SQLITE_PATH=./data/jira-intake.db

# Auth: demo@agentos.ai / agentos123 works by default. Set true to allow any email+8+ char password.
# AUTH_ALLOW_ANY_LOGIN=true

# Optional: pipeline worker parallelism (default 2)
# PIPELINE_WORKER_CONCURRENCY=2

# Monitoring
SENTRY_DSN=
