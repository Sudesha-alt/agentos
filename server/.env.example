NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Postgres (Supabase). Must have pgvector extension enabled.
# Dashboard → Connect → Session pooler (port 5432). Example:
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings → API → service_role (secret). Never commit the real value.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Claude agents: bedrock (default in this project) or anthropic
LLM_PROVIDER=bedrock
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-40-character-secret-access-key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
# AWS_SESSION_TOKEN=   # only if using temporary credentials

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_ID=claude-sonnet-4-20250514

OPENAI_API_KEY=

# Jira (pipelines + board search + AI Worker intake)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_BOARD_ID=
JIRA_WEBHOOK_SECRET=

# AI Worker intake (SQLite queue — no Postgres required)
AI_WORKER_STATUSES=AI Worker
# SQLITE_PATH=./data/jira-intake.db

# Optional: pipeline worker parallelism (default 2)
# PIPELINE_WORKER_CONCURRENCY=2

# Monitoring
SENTRY_DSN=
