{
  "name": "agentos",
  "private": true,
  "description": "Agentos monorepo — app (Vercel) + server (Render)",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/start.ps1",
    "dev:app": "npm run dev --prefix app",
    "dev:api": "npm run dev --prefix server",
    "tunnel": "powershell -ExecutionPolicy Bypass -File scripts/tunnel.ps1",
    "build": "npm run build --prefix app",
    "build:app": "npm run build --prefix app",
    "build:server": "npm run build --prefix server",
    "lint": "npm run lint --prefix app",
    "test": "npm run test --prefix app",
    "install:all": "npm install --prefix app && npm install --prefix server"
  }
}
