# Production API (no trailing slash). Set the same in Vercel → Environment Variables.
VITE_API_URL=https://agentos-sc05.onrender.com

# mock | rest — optional when VITE_API_URL is set (REST is auto-selected).
# Explicitly set rest for production; use mock only for offline UI dev without a server.
VITE_API_MODE=rest

